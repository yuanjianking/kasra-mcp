# IAC-09: Terraform Network Security — MongoDB port 27017 exposed
# Additional test: 27017 exposed to 0.0.0.0/0
resource "aws_security_group" "mongodb" {
  name        = "mongodb-exposed"
  description = "MongoDB security group with open port"

  ingress {
    from_port   = 27017
    to_port     = 27017
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "MongoDB from anywhere"
  }

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH from anywhere"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}
